# 環境変数のサンプル。コピーして .env を作成し、本番では必ず値を変更すること。
#   cp .env.example .env
# .env は .gitignore 済み（コミットしない）。
#
# Django はこのファイルを自動では読み込みません（python-dotenv等は未導入）。
# 開発中は未設定でOK（settings.py の開発用デフォルトが使われます）。
# 本番ではプロセス起動時の環境変数としてこれらを与えてください。

# 本番用のランダムな秘密鍵（開発用デフォルトは使わない）。
# 生成例: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# 本番では False
DJANGO_DEBUG=True

# 本番で許可するホスト（カンマ区切り）。例: example.com,www.example.com
DJANGO_ALLOWED_HOSTS=
